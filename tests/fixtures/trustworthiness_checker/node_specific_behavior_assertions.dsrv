in message_generated_node_0

// Every message_generated event now carries a "role" field recording which
// role node 0 held at the moment the message was produced.  Discriminating
// on that field makes this a single-stream spec, which avoids the multi-stream
// is_defined pitfall where is_defined(live_stream) always returns true because
// stream_lift_base replays the last value rather than signalling NoVal.
//
// - Follower:   only sends RequestVoteResponse and AppendEntriesResponse;
//               reacts to incoming messages but never initiates elections or heartbeats.
// - Candidate:  sends RequestVote plus response messages, but never AppendEntries.
// - Leader:     sends AppendEntries (heartbeats) plus response messages,
//               but never RequestVote.
out role_behavior_ok: Bool

role_behavior_ok =
  if Map.get(message_generated_node_0, "role") == "follower" then
    !(Map.get(message_generated_node_0, "msg_type") == "RequestVote") &&
    !(Map.get(message_generated_node_0, "msg_type") == "AppendEntries")
  else if Map.get(message_generated_node_0, "role") == "candidate" then
    !(Map.get(message_generated_node_0, "msg_type") == "AppendEntries")
  else if Map.get(message_generated_node_0, "role") == "leader" then
    !(Map.get(message_generated_node_0, "msg_type") == "RequestVote")
  else false
