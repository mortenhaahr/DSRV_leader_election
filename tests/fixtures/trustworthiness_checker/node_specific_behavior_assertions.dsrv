in node_role_transition
in message_generated

// Track the current role of node 0 across all events.
// Updated on every node_role_transition that targets node 0;
// held at its last value otherwise (defaulting to "follower" before
// the first transition is seen).
aux node_0_role

out role_behavior_ok: Bool

node_0_role =
  if is_defined(node_role_transition) then
    if Map.get(node_role_transition, "node_id") == 0 then
      Map.get(node_role_transition, "to_role")
    else
      default(node_0_role[1], "follower")
  else
    default(node_0_role[1], "follower")

// For every message generated by node 0, verify that the message type is
// consistent with the role node 0 holds at the time of generation.
//
// Follower  (FR-5): only sends RequestVoteResponse and AppendEntriesResponse —
//                   it reacts to incoming messages but never initiates elections
//                   or heartbeats.
// Candidate (CR-3): sends RequestVote (election solicitation) plus response
//                   messages, but never AppendEntries — it is not a leader yet.
// Leader    (LR-2): sends AppendEntries (heartbeats) plus response messages,
//                   but never RequestVote — it does not run as a candidate.
role_behavior_ok =
  if is_defined(message_generated) then
    if Map.get(message_generated, "node_id") == 0 then
      if node_0_role == "follower" then
        !(Map.get(message_generated, "msg_type") == "RequestVote") &&
        !(Map.get(message_generated, "msg_type") == "AppendEntries")
      else if node_0_role == "candidate" then
        !(Map.get(message_generated, "msg_type") == "AppendEntries")
      else if node_0_role == "leader" then
        !(Map.get(message_generated, "msg_type") == "RequestVote")
      else false
    else true
  else true
