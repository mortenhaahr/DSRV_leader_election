in message_generated_node_0

// Per-message implications: role => message-type and term > 0 constraints.
//
// - follower_ok:  being a follower implies never sending RequestVote or
//                 AppendEntries, and every message has term > 0.
// - candidate_ok: being a candidate implies never sending AppendEntries,
//                 and every message has term > 0.
// - leader_ok:    being a leader implies never sending RequestVote,
//                 and every message has term > 0.
// - node_0_ok:    conjunction of all three.
out follower_ok: Bool
out candidate_ok: Bool
out leader_ok: Bool
out node_0_ok: Bool

follower_ok =
  (Map.get(message_generated_node_0, "role") == "follower") =>
  (!(Map.get(message_generated_node_0, "msg_type") == "RequestVote") &&
   !(Map.get(message_generated_node_0, "msg_type") == "AppendEntries") &&
   (Map.get(message_generated_node_0, "term") > 0))

candidate_ok =
  (Map.get(message_generated_node_0, "role") == "candidate") =>
  (!(Map.get(message_generated_node_0, "msg_type") == "AppendEntries") &&
   (Map.get(message_generated_node_0, "term") > 0))

leader_ok =
  (Map.get(message_generated_node_0, "role") == "leader") =>
  (!(Map.get(message_generated_node_0, "msg_type") == "RequestVote") &&
   (Map.get(message_generated_node_0, "term") > 0))

node_0_ok = follower_ok && candidate_ok && leader_ok
