in message_generated_node_0

// Per-role properties:
//
// - follower_term_ok:      consecutive follower messages have non-decreasing
//                          term.  A follower's term can rise without any role
//                          transition (when it accepts a higher-term request),
//                          so >= rather than == is the correct bound.
//
// - candidate_broadcast_ok: within the same election (identified by equal
//                          term), consecutive RequestVote messages must target
//                          different receivers.  A candidate broadcasts exactly
//                          one solicitation per peer per epoch.
//
// - leader_broadcast_ok:   within the same leader epoch (equal term),
//                          consecutive AppendEntries messages must target
//                          different receivers.  A leader cycles through all
//                          peers and never sends two heartbeats to the same
//                          peer consecutively.
//
// - node_0_ok:             conjunction of all three.
out follower_term_ok: Bool
out candidate_broadcast_ok: Bool
out leader_broadcast_ok: Bool
out node_0_ok: Bool

follower_term_ok =
  ((Map.get(message_generated_node_0, "role") == "follower") &&
   (Map.get(message_generated_node_0[1], "role") == "follower")) =>
  (Map.get(message_generated_node_0, "term") >= Map.get(message_generated_node_0[1], "term"))

candidate_broadcast_ok =
  ((Map.get(message_generated_node_0, "role") == "candidate") &&
   (Map.get(message_generated_node_0[1], "role") == "candidate") &&
   (Map.get(message_generated_node_0, "msg_type") == "RequestVote") &&
   (Map.get(message_generated_node_0[1], "msg_type") == "RequestVote") &&
   (Map.get(message_generated_node_0, "term") == Map.get(message_generated_node_0[1], "term"))) =>
  !(Map.get(message_generated_node_0, "receiver") == Map.get(message_generated_node_0[1], "receiver"))

leader_broadcast_ok =
  ((Map.get(message_generated_node_0, "role") == "leader") &&
   (Map.get(message_generated_node_0[1], "role") == "leader") &&
   (Map.get(message_generated_node_0, "msg_type") == "AppendEntries") &&
   (Map.get(message_generated_node_0[1], "msg_type") == "AppendEntries") &&
   (Map.get(message_generated_node_0, "term") == Map.get(message_generated_node_0[1], "term"))) =>
  !(Map.get(message_generated_node_0, "receiver") == Map.get(message_generated_node_0[1], "receiver"))

node_0_ok = follower_term_ok && candidate_broadcast_ok && leader_broadcast_ok
